{
  "name": "ai-chat-agent-server",
  "version": "1.0.0",
  "description": "Backend for AI Chat Agent",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc && node scripts/copy-assets.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run typecheck && npm run test && npm run build && npm run audit:prod",
    "build:docker": "docker compose build",
    "init-db": "ts-node scripts/init-db.ts",
    "ensure-db": "ts-node scripts/ensure-db.ts",
    "factory:smoke": "ts-node scripts/factory-smoke.ts",
    "factory:smoke:full": "ts-node scripts/factory-smoke.ts --phase2",
    "test:ui-build": "ts-node scripts/test-ui-build.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.1",
    "@sentry/node": "^10.56.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "fast-xml-parser": "^5.8.0",
    "groq-sdk": "^0.37.0",
    "jose": "^5.10.0",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "premium-lead-generation-chatbot": "file:..",
    "puppeteer": "^24.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.8",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
