# ============================================================================
#  server/.env  ==  OVERRIDES OPTIONNELS du backend (V2)
# ----------------------------------------------------------------------------
#  La SOURCE DE VERITE est le ".env" a la RACINE du depot : il est charge par
#  le backend (server/src/env.ts, couche de base) ET par le frontend.
#  Ce fichier server/.env n'est PAS requis ; s'il existe, ses valeurs ecrasent
#  celles du .env racine (en non-production uniquement).
#  -> Pour un setup simple/clair : tout mettre dans le .env RACINE et ne PAS
#     creer server/.env.
#  Cles indispensables (dans le .env racine) : DATABASE_URL, GROQ_API_KEY,
#  ADMIN_API_KEY, JWT_SECRET (>=32 car.), ADMIN_SESSION_SECRET (distinct).
# ============================================================================
NODE_ENV=development
PORT=3001
DATABASE_URL=
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

ADMIN_API_KEY=
ADMIN_SESSION_SECRET=
JWT_SECRET=
JWT_TTL_SECONDS=1200
JWT_ALG=HS256
WIDGET_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WIDGET_TENANT_MAP=default:default

LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=

CRM_PROVIDER=none
CRM_MIN_PUSH_SCORE=60
AIRTABLE_WEBHOOK_URL=
TWENTY_API_URL=
TWENTY_API_KEY=

BOT_PROFILE=garage_motrio
RAG_ENABLED=true
KNOWLEDGE_URLS=
KNOWLEDGE_CACHE_TTL=3600

SENTRY_DSN=
APP_RELEASE=local
