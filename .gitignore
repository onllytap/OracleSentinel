# ─────────────────────────────────────────────
# OracleSentinel / Sentinel — .gitignore
# Hygiène secrets : ne JAMAIS committer de valeurs réelles.
# ─────────────────────────────────────────────

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
coverage/
playwright-report/
test-results/
*.log

# Environment files & secrets
.env
.env.*
!.env.example
*.env.backup
*.env.bak
.env.backup.*

# Local secret/config dumps
ORACLESENTINEL_CONFIG.txt
**/ORACLESENTINEL_CONFIG.txt
*_CONFIG.local.txt

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/
