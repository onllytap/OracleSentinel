# ─────────────────────────────────────────────
# OracleSentinel / Sentinel — .gitignore
# Hygiène secrets : ne JAMAIS committer de valeurs réelles.
# ─────────────────────────────────────────────

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
coverage/
playwright-report/
test-results/
*.log

# Environment files & secrets
.env
.env.*
!.env.example
*.env.backup
*.env.bak
.env.backup.*

# Local secret/config dumps
ORACLESENTINEL_CONFIG.txt
**/ORACLESENTINEL_CONFIG.txt
*_CONFIG.local.txt

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
.cache/

# ---------------------------------------------
# AI assistant / tool local folders (per-developer) - NOT versioned.
# Each IDE/assistant creates its own local config/skills folder; these are
# environment-specific and must not pollute the repo. This also clears the
# stale git status warnings about deleted .agent/skills/ folders.
# Intentionally KEPT tracked (useful shared config, do NOT ignore):
# .kiro/ (specs + settings), .github/ (CI/workflows), .vscode/ (handled above),
# .agents/ (versioned skills library, ~359 tracked files).
# ---------------------------------------------
.agent/
.cursor/
.gemini/
.qoder/
.windsurf/
.kilocode/
.opencode/

# Server logs (already matched by *.log above; listed explicitly for clarity)
server.log
