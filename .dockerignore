# ---------------------------------------------
# OracleSentinel / Sentinel - .dockerignore
# Keep production images small and secret-free.
# Owned by C1 (repo hygiene). Applies to any docker build using the repo root as context.
# ---------------------------------------------

# Version control & git metadata
.git/
.gitignore
.gitattributes
.dockerignore

# Dependencies (reinstalled inside the image)
node_modules/
**/node_modules/

# Build outputs (rebuilt inside the image)
build/
dist/
**/dist/
coverage/
playwright-report/
test-results/
.cache/

# Secrets & environment files - NEVER ship these in an image
.env*
*.env.backup*
*.env.bak
ORACLESENTINEL_CONFIG.txt
**/ORACLESENTINEL_CONFIG.txt
*_CONFIG.local.txt

# Logs
*.log
server.log

# Tests & fixtures (not needed at runtime)
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
tests/
e2e/

# Documentation (not needed at runtime)
bibliotheque/
docs/
*.md

# AI assistant / tool local folders
.agent/
.agents/
.claude/
.cursor/
.gemini/
.kilocode/
.kiro/
.opencode/
.qoder/
.windsurf/

# Separate sub-projects / working copies (not part of the prod image)
Chatbot/
ai-chat-agent-main/
pratice/
profiles/
skills/

# IDE & OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
