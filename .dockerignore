# ============================================================================
# Root .dockerignore — build context for Dockerfile.production (repo root)
# ============================================================================
# Dockerfile.production copies only explicit paths (package.json, *.config.*,
# index.html, factory-dashboard.html, src/, public/, server/...). This file is
# defense-in-depth: it keeps secrets, env backups and AI-tool configs OUT of
# the build context/image, and shrinks the context. Do NOT add entries that
# match the paths the Dockerfile needs to COPY.
# ----------------------------------------------------------------------------

# ── Dependencies (installed inside the image) ───────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build output (produced inside the image) ────────────────────────────────
build/
dist/
server/dist/
.vite/
coverage/
playwright-report/
test-results/
.nyc_output/

# ── Secrets & environment files (mounted at runtime, NEVER baked in) ─────────
.env
.env.*
*.env
*.env.*
.env.backup.*
*.env.backup*
*.local
ORACLESENTINEL_CONFIG.txt
*_CONFIG.txt
*.pem
*.key
secrets/

# ── Git ──────────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── AI / assistant tool configs (not part of the product) ───────────────────
.agent/
.agents/
.claude/
.cursor/
.gemini/
.kilocode/
.kiro/
.opencode/
.qoder/
.windsurf/

# ── Documentation (not needed at runtime) ───────────────────────────────────
bibliotheque/
docs/
*.md
LICENSE

# ── Separate work copies / sub-repos (large, not part of this image) ─────────
Chatbot/
ai-chat-agent-main/

# ── Dev-only scripts & local tooling ────────────────────────────────────────
scripts/
**/__pycache__/

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & temp ──────────────────────────────────────────────────────────────
*.log
server.log
tmp/
temp/

# ── Docker artifacts ─────────────────────────────────────────────────────────
.dockerignore
docker-compose*.yml
Dockerfile*
