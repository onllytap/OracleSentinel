NODE_ENV=development
VITE_API_URL=http://localhost:3001
VITE_WIDGET_ID=default
VITE_COMPANY_PHONE=0970 808 911
VITE_SENTRY_DSN=
VITE_APP_RELEASE=local

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Workers — supervision QG (/qg → onglet Workers)
# Phase 1 = lecture seule. Token avec la permission MINIMALE "Workers Scripts: Read".
# (On élèvera à "Edit" seulement à la Phase 2 quand le redéploiement sera activé.)
# Laisser vide = l'onglet Workers affiche "Cloudflare non configuré" (aucun crash).
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Sous-domaine workers.dev du compte (sert à construire l'URL de health-ping).
CLOUDFLARE_WORKERS_SUBDOMAIN=
