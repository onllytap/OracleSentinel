NODE_ENV=development
VITE_API_URL=http://localhost:3001
VITE_WIDGET_ID=default
VITE_COMPANY_PHONE=0970 808 911
VITE_SENTRY_DSN=
VITE_APP_RELEASE=local

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Workers — supervision QG (/qg → onglet Workers)
# Phase 1 = lecture seule. Token avec la permission MINIMALE "Workers Scripts: Read".
# (On élèvera à "Edit" seulement à la Phase 2 quand le redéploiement sera activé.)
# Laisser vide = l'onglet Workers affiche "Cloudflare non configuré" (aucun crash).
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Sous-domaine workers.dev du compte (sert à construire l'URL de health-ping).
CLOUDFLARE_WORKERS_SUBDOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# v2.1 — Plateforme multi-agences (CRM par agence chiffré, facturation, TOTP)
# ─────────────────────────────────────────────────────────────────────────────
# Clé de chiffrement des secrets au repos (creds CRM par agence + secret TOTP).
# 64 hex = 32 octets. Générer avec: openssl rand -hex 32
# PROD: OBLIGATOIRE (sans elle, le serveur refuse de manipuler des secrets).
# DEV : si vide, une clé dérivée est utilisée (avertissement, jamais en prod).
APP_ENCRYPTION_KEY=

# Facturation Stripe — DÉSACTIVÉE par défaut. false = aucun métering/paywall/Stripe.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=

# Break-glass d'authentification admin (R14.4) — DISTINCT de ADMIN_API_KEY.
# Permet d'établir une session sans TOTP en cas d'urgence ; chaque usage est audité.
ADMIN_BREAK_GLASS=
